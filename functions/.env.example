# ─────────────────────────────────────────────────────────────────────────
# Cloud Functions environment variables.
# Configure via Firebase params (defineString) or as Secret Manager
# (defineSecret) values. Anything sensitive should be a Secret, not env.
# ─────────────────────────────────────────────────────────────────────────

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM_ADDRESS=AutoLienTracker <noreply@autolientracker.com>

# Telnyx (SMS)
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX
TELNYX_MESSAGING_PROFILE_ID=
# Base64-encoded Ed25519 public key from Telnyx Messaging Profile → Webhook signing.
# Required in production; webhook rejects unsigned/stale requests.
TELNYX_PUBLIC_KEY=
# Set to "false" only in dev/emulator to disable signature verification.
TELNYX_WEBHOOK_ENFORCE=true

# Stripe (use Secret Manager for the secret key + webhook secret)
# Configured via defineSecret(STRIPE_SECRET_KEY) and defineSecret(STRIPE_WEBHOOK_SECRET)
# Plan price IDs — must match the live or test price IDs in your Stripe account.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# Google Gemini (insurance card OCR + customer extraction)
GEMINI_API_KEY=

# Cloud Run engine
DATA_FEED_ENGINE_URL=https://your-engine.run.app
# Shared secret sent as `x-engine-secret` header on every engine call.
# Must match ENGINE_SHARED_SECRET on the engine service.
ENGINE_SHARED_SECRET=
