# Smartproxy residential proxy
SMARTPROXY_USER=your_smartproxy_username
SMARTPROXY_PASS=your_smartproxy_password

# Google AI (Gemini Flash)
GOOGLE_AI_API_KEY=your_google_ai_api_key

# CapSolver
CAPSOLVER_API_KEY=your_capsolver_api_key

# GCP Project (for Firestore access)
GCP_PROJECT_ID=insurance-track-os

# IMAP for reading OTP/MFA codes from carrier portals
IMAP_USER=info@autolientracker.com
IMAP_APP_PASSWORD=your_google_app_password

# Carrier credential encryption (64 hex chars = 32 bytes)
CREDENTIAL_ENCRYPTION_KEY=your_64_hex_char_key_here

# Port (Cloud Run sets this automatically)
PORT=8080
